{
  "compilerOptions": {
    "target": "es2022",
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    // "module": "ESNext",
    "moduleResolution": "node",
    "noImplicitAny": false,
    "outDir": "./dist",
    "sourceMap": true,
    "pretty": true
  },
  "include": ["*.ts"],
  "paths": {
    "@aptos/*": "../.."
  }
}
